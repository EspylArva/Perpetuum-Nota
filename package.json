{
  "name": "stickynotes",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "shared",
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev:db": "docker compose -f docker-compose.dev.yml up -d",
    "dev:db:down": "docker compose -f docker-compose.dev.yml down",
    "dev:api": "npm run start:dev --workspace backend",
    "dev:web": "npm start --workspace frontend",
    "build:backend": "npm run build --workspace backend",
    "build:frontend": "npm run build --workspace frontend",
    "test:backend": "npm test --workspace backend",
    "prisma": "npm run prisma --workspace backend --",
    "up": "docker compose up --build",
    "down": "docker compose down"
  }
}
