# ---- PostgreSQL ----
POSTGRES_USER=perpetuum_nota
POSTGRES_PASSWORD=change-me-in-prod
POSTGRES_DB=perpetuum_nota

# ---- Backend (NestJS) ----
# Secrets: generate a UNIQUE value per environment (never reuse dev in prod):
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# Signs JWTs (httpOnly cookie auth):
JWT_SECRET=change-me-to-a-long-random-string
# Signs CSRF double-submit tokens (falls back to JWT_SECRET if unset; set it):
CSRF_SECRET=change-me-to-a-different-long-random-string
# Admin account bootstrapped on first boot (idempotent)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-admin-password
# Break-glass admin recovery: uncomment, restart the api (resets the admin's
# password to ADMIN_PASSWORD + restores role/active), log in, then REMOVE the
# flag — it re-applies on every boot while set. See BACKUP.md.
# ADMIN_FORCE_PASSWORD_RESET=true
# Where uploaded image files are written (mounted as a named volume in Docker)
UPLOADS_DIR=/data/uploads

# ---- Web (single public URL) ----
# Host port mapped to the nginx front door
WEB_PORT=8080

# ---- Image tags (docker-compose.prod.yml) ----
# Which image tag the NAS pulls for the api/web services. Default is `latest`;
# pin a specific release printed by scripts/deploy-to-zot.sh for reproducible
# rollbacks (e.g. API_TAG=1.2.0 WEB_TAG=1.2.0).
# API_TAG=latest
# WEB_TAG=latest

# ---- NAS deploy (scripts/deploy-to-zot.sh only — NOT read by the app) ----
# See DEPLOY.md. The self-hosted Zot OCI registry on the NAS that prod images are
# pushed to (also the source the NAS pulls from):
ZOT_URL=https://your-nas.tailnet.ts.net:5000/
# Registry credentials — or run `docker login <host:port>` once and omit these:
# ZOT_USERNAME=
# ZOT_PASSWORD=
# Password for ./cosign.key (image signing; signing is skipped if this is unset):
COSIGN_PASSWORD=change-me-cosign-key-password
