generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum Visibility {
  PRIVATE
  PUBLIC
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  displayName  String
  passwordHash String
  role         Role     @default(USER)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  notes          Note[]
  editedNotes    Note[]       @relation("LastEditor")
  sharedNotes    NoteShare[]
  invitesSent    Invite[]     @relation("InvitedBy")
  uploadedImages ImageAsset[]
  tags           Tag[]
  folders        Folder[]
}

model Invite {
  id          String    @id @default(uuid())
  email       String
  tokenHash   String    @unique
  role        Role      @default(USER)
  invitedById String
  invitedBy   User      @relation("InvitedBy", fields: [invitedById], references: [id], onDelete: Cascade)
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@index([email])
}

model Note {
  id               String     @id @default(uuid())
  ownerId          String
  owner            User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  // The user who most recently edited content/meta/tags. Null = never edited
  // since creation. Today only the owner can edit; this generalises if shared
  // editing ever lands. SetNull keeps the note if the editor is deleted.
  lastEditedById   String?
  lastEditedBy     User?      @relation("LastEditor", fields: [lastEditedById], references: [id], onDelete: SetNull)
  title            String     @default("")
  content          Json       // ProseMirror / TipTap document (jsonb)
  // Plain text extracted from `content` at write time; feeds full-text search
  // (GIN index over title + contentText, added via raw SQL in the migration)
  // and the list preview (first 160 chars) without re-walking the JSON per read.
  contentText      String     @default("")
  visibility       Visibility @default(PRIVATE)
  position         Float      @default(0) // sort order; lower = earlier. Float enables fractional inserts without a full renumber.
  pinned           Boolean    @default(false)
  // Wall-view grid coordinates in grid-cell units (top-left corner). Null =
  // never placed by hand; the client auto-flows unplaced notes. Owner-set only.
  wallX            Int?
  wallY            Int?
  // Soft delete (trash). Null = live; set = in trash, hard-purged ~30 days later.
  deletedAt        DateTime?
  // Optional due date. Plain timestamp; the client owns local-day bounds.
  dueDate          DateTime?
  // Organizational folder (owner-scoped tree). Null = lives at the root. A note
  // is in at most one folder. SetNull keeps the note when its folder is deleted
  // (the service reparents up before delete; this is just the DB backstop).
  folderId         String?
  folder           Folder?    @relation(fields: [folderId], references: [id], onDelete: SetNull)
  contentUpdatedAt DateTime   @default(now())
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  shares NoteShare[]
  images ImageAsset[]
  tags   NoteTag[]

  @@index([ownerId])
  @@index([ownerId, position])
  @@index([ownerId, deletedAt])
  @@index([ownerId, dueDate])
  @@index([ownerId, folderId])
  @@index([deletedAt])
}

// Owner-scoped nested folders (Evernote-style notebook tree). A note lives in
// at most one folder; folders can nest arbitrarily. Deleting a folder via the
// service reparents its children + notes up to the parent (transaction) before
// removing the row — the onDelete: Cascade on the self-relation is only a
// DB-level backstop and is never the path the service takes.
model Folder {
  id        String   @id @default(uuid())
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name      String
  parentId  String?
  parent    Folder?  @relation("FolderTree", fields: [parentId], references: [id], onDelete: Cascade)
  children  Folder[] @relation("FolderTree")
  notes     Note[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId, parentId])
}

// Explicit per-user view grants on PRIVATE notes (view-only in the MVP).
model NoteShare {
  noteId    String
  note      Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  // When the recipient first opened the note after this grant; null = unseen
  // (drives the "Shared with me" badge).
  seenAt    DateTime?

  @@id([noteId, userId])
  @@index([userId])
}

// Owner-scoped labels (Evernote-style). Tag names are unique per owner;
// attaching is restricted to the note owner (tags never cross accounts).
model Tag {
  id        String    @id @default(uuid())
  ownerId   String
  owner     User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name      String
  createdAt DateTime  @default(now())

  notes NoteTag[]

  @@unique([ownerId, name])
}

model NoteTag {
  noteId String
  note   Note   @relation(fields: [noteId], references: [id], onDelete: Cascade)
  tagId  String
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([noteId, tagId])
  @@index([tagId])
}

// Uploaded image files. The ProseMirror image node references these by id (/api/uploads/:id),
// not by file path. Image size/position live in the doc JSON node attrs, not here.
model ImageAsset {
  id           String   @id @default(uuid())
  noteId       String
  note         Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)
  uploadedById String
  uploadedBy   User     @relation(fields: [uploadedById], references: [id], onDelete: Cascade)
  storagePath  String
  mimeType     String
  sizeBytes    Int
  width        Int
  height       Int
  createdAt    DateTime @default(now())

  @@index([noteId])
}
